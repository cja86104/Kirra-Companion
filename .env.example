# =============================================================================
# KIRRA COMPANION - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your values

# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# AI PROVIDERS
# -----------------------------------------------------------------------------
# DeepSeek (recommended for cost-effective AI)
DEEPSEEK_API_KEY=your-deepseek-api-key

# OpenAI (for TTS and fallback)
OPENAI_API_KEY=your-openai-api-key

# Anthropic (optional, for premium features)
ANTHROPIC_API_KEY=your-anthropic-api-key

# -----------------------------------------------------------------------------
# STRIPE (for subscriptions)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# -----------------------------------------------------------------------------
# APP CONFIGURATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron job authentication
CRON_SECRET=your-random-cron-secret

# -----------------------------------------------------------------------------
# OPTIONAL: EMAIL (for notifications)
# -----------------------------------------------------------------------------
# Uncomment and configure one of these if using email features:
# RESEND_API_KEY=your-resend-api-key
# EMAIL_FROM=Kirra <noreply@your-domain.com>
# SUPPORT_EMAIL=support@your-domain.com
