# =============================================================================
# Kirra Companion — environment template
#
# Copy this file to .env.local and fill in real values for your environment.
# Do NOT commit .env.local. Every key the application actually reads is
# listed below; if you see a process.env.* reference in code that is not
# documented here, that is a regression — please update this template.
#
# Source of truth: a grep of `process.env.[A-Z_]+` across the repo at
# the time this template was generated (Section 4a).
#
# Sections:
#   1. Supabase (required)
#   2. LLM — chat (required)
#   3. LLM — embeddings + TTS (required)
#   4. Image generation (required only for scene generation)
#   5. Stripe (required for billing — empty disables paid tiers)
#   6. App (required)
#   7. Cron (required for /api/cron/* endpoints)
#   8. Email (required for transactional email)
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Supabase
# -----------------------------------------------------------------------------
# Project URL. Dashboard → Project Settings → API → Project URL.
# Format: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anonymous (public) API key. Dashboard → Project Settings → API → anon public.
# Safe to expose to the browser; RLS policies enforce per-user data scope.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role (admin) API key. Dashboard → Project Settings → API → service_role.
# Bypasses RLS. SERVER-SIDE ONLY — never import into a client component or
# expose in any NEXT_PUBLIC_* variable. Used by admin clients, cron jobs,
# Stripe webhooks, and rate-limit infrastructure.
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# 2. LLM — chat (OpenRouter is the sole chat provider per CLAUDE.md)
# -----------------------------------------------------------------------------
# OpenRouter API key. https://openrouter.ai/keys
# Routed to DeepSeek V3 via lib/ai/chat-client.ts (generateSimpleCompletion).
# Format: sk-or-v1-...
OPENROUTER_API_KEY=


# -----------------------------------------------------------------------------
# 3. LLM — embeddings + TTS
# -----------------------------------------------------------------------------
# OpenAI API key. https://platform.openai.com/api-keys
# Per CLAUDE.md the `openai` package is permitted only in:
#   - lib/ai/embeddings.ts   (vector embeddings for memory retrieval)
#   - lib/tts/openai-tts.ts  (text-to-speech voice synthesis)
# Format: sk-proj-... or sk-...
OPENAI_API_KEY=


# -----------------------------------------------------------------------------
# 4. Image generation
# -----------------------------------------------------------------------------
# Segmind API key — used by /api/companion/[id]/generate-scene for runtime
# scene image generation. https://www.segmind.com/console/api-keys
SEGMIND_API_KEY=

# fal.ai API key — used by scripts/generate-scenes.ts for batch/offline scene
# generation. https://fal.ai/dashboard/keys
# Optional if you do not run the offline generation script.
FAL_KEY=


# -----------------------------------------------------------------------------
# 5. Stripe
# -----------------------------------------------------------------------------
# Stripe secret key. Dashboard → Developers → API keys → Secret key.
# Use sk_test_... in development, sk_live_... in production.
# Empty value disables all paid-tier flows (checkout, portal, webhook).
STRIPE_SECRET_KEY=

# Webhook signing secret for /api/stripe/webhook.
# Dashboard → Developers → Webhooks → (your endpoint) → Signing secret.
# Format: whsec_...
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs for each tier × billing period.
# Dashboard → Products → (product) → Pricing → API ID.
# Format: price_...
# Tier definitions: see CLAUDE.md "Subscription Tiers" section.
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_BASIC_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ULTIMATE_MONTHLY=
STRIPE_PRICE_ULTIMATE_YEARLY=


# -----------------------------------------------------------------------------
# 6. App
# -----------------------------------------------------------------------------
# Public base URL of the deployed application. Used to construct:
#   - OAuth callback URLs and Stripe success/cancel URLs
#   - Email links (verification, password reset, transactional)
#   - HTTP-Referer header sent to OpenRouter
# Local dev: http://localhost:3000
# Production: https://<your-domain>  (NO trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# 7. Cron
# -----------------------------------------------------------------------------
# Shared secret required by every /api/cron/* endpoint.
# The cron caller (Vercel Cron, Upstash QStash, GitHub Actions, etc.) must
# send this value in the Authorization header: `Bearer ${CRON_SECRET}`.
# Generate with: openssl rand -hex 32
CRON_SECRET=


# -----------------------------------------------------------------------------
# 8. Email (Resend)
# -----------------------------------------------------------------------------
# Resend API key. https://resend.com/api-keys
# Format: re_...
RESEND_API_KEY=

# From address for transactional email. Must be on a domain you have verified
# in Resend (or use onboarding@resend.dev for sandbox testing only).
# Format: "Kirra <hello@your-verified-domain>"
EMAIL_FROM=

# Reply-to address surfaced in support-related transactional email.
SUPPORT_EMAIL=
